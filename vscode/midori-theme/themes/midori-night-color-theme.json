  "tokenColors": [
    {
      "name": "Comment — derived quiet warm gray (bone washed into charcoal)",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#837d72", "fontStyle": "italic" }
    },
    {
      "name": "String — midori-olive (lifted)",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#9eaf85" }
    },
    {
      "name": "Escapes & regex — dot-grid mint",
      "scope": [
        "constant.character.escape",
        "string.regexp",
        "constant.other.character-class",
        "punctuation.definition.template-expression"
      ],
      "settings": { "foreground": "#9ebfb4" }
    },
    {
      "name": "Numbers & constants — terracotta (accent-warm)",
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant",
        "constant.other",
        "keyword.other.unit"
      ],
      "settings": { "foreground": "#d4a07a" }
    },
    {
      "name": "Keywords & storage — midori-indigo (fountain-pen ink, lifted)",
      "scope": ["keyword", "keyword.control", "storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#6c87a4" }
    },
    {
      "name": "Operators & punctuation — muted ink",
      "scope": ["keyword.operator", "punctuation", "meta.brace"],
      "settings": { "foreground": "#9c958a" }
    },
    {
      "name": "Functions — midori-ochre",
      "scope": ["entity.name.function", "support.function", "meta.function-call.generic"],
      "settings": { "foreground": "#d8b06a" }
    },
    {
      "name": "Types & classes — midori-wine",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "support.type",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": { "foreground": "#b8868a" }
    },
    {
      "name": "Variables — bone ink",
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#ebe8e2" }
    },
    {
      "name": "Parameters — eyebrow ink (accent-mythic), italic",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#c4b8a8", "fontStyle": "italic" }
    },
    {
      "name": "Properties — derived plum (wine × indigo)",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": { "foreground": "#a48ba3" }
    },
    {
      "name": "this / self — plum italic",
      "scope": ["variable.language"],
      "settings": { "foreground": "#a48ba3", "fontStyle": "italic" }
    },
    {
      "name": "Decorators & annotations — plum",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "punctuation.decorator",
        "storage.type.annotation"
      ],
      "settings": { "foreground": "#a48ba3" }
    },
    {
      "name": "Tags — indigo",
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": { "foreground": "#6c87a4" }
    },
    {
      "name": "Attributes — ochre italic",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#d8b06a", "fontStyle": "italic" }
    },
    {
      "name": "CSS property names — muted ink",
      "scope": ["support.type.property-name.css", "support.type.vendored.property-name.css"],
      "settings": { "foreground": "#9c958a" }
    },
    {
      "name": "JSON keys — indigo",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#6c87a4" }
    },
    {
      "name": "Markdown heading — bone ink, bold",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": { "foreground": "#ebe8e2", "fontStyle": "bold" }
    },
    {
      "name": "Markdown heading / list punctuation — sage as punctuation",
      "scope": ["punctuation.definition.heading", "punctuation.definition.list"],
      "settings": { "foreground": "#9aab97" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic" }
    },
    {
      "name": "Markdown quote — eyebrow ink italic",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#c4b8a8", "fontStyle": "italic" }
    },
    {
      "name": "Markdown inline code — warm",
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": { "foreground": "#d4a07a" }
    },
    {
      "name": "Links — indigo lifted",
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": { "foreground": "#8ba3bd" }
    },
    {
      "name": "Diff / markup inserted — olive",
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#9eaf85" }
    },
    {
      "name": "Diff / markup deleted — warm deep",
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#b87d5c" }
    },
    {
      "name": "Diff / markup changed — ochre",
      "scope": ["markup.changed"],
      "settings": { "foreground": "#d8b06a" }
    },
    {
      "name": "Diff headers — indigo",
      "scope": ["meta.diff.header", "meta.diff.range"],
      "settings": { "foreground": "#6c87a4" }
    },
    {
      "name": "Invalid — warm deep (site alert color, not red)",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#b87d5c" }
    }
  ],
  "semanticTokenColors": {
    "parameter": { "foreground": "#c4b8a8", "italic": true },
    "property": "#a48ba3",
    "type": "#b8868a",
    "class": "#b8868a",
    "interface": "#b8868a",
    "enum": "#b8868a",
    "namespace": "#b8868a",
    "function": "#d8b06a",
    "method": "#d8b06a",
    "decorator": "#a48ba3"
  }
}
