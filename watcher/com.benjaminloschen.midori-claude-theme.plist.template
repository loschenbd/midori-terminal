<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.benjaminloschen.midori-claude-theme</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/sh</string>
    <string>__HOME__/.local/bin/midori-claude-theme.sh</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/tmp/midori-claude-theme.out</string>
  <key>StandardErrorPath</key>
  <string>/tmp/midori-claude-theme.err</string>
</dict>
</plist>
