# Midori terminal theme — shell fragment
# Sourced from ~/.zshrc by midori-terminal/install.sh. Everything here speaks
# ANSI-16 color names/indices, so it retints automatically when the Ghostty
# theme pair (midori-paper / midori-night) flips with macOS appearance.

# Re-entrancy guard: makes a second source a no-op so the precmd hook and
# oh-my-posh init below aren't registered twice (double prompt render / double
# OSC 112) when a config re-sources this fragment.
[ -n "$_MIDORI_ZSHRC_SOURCED" ] && return
_MIDORI_ZSHRC_SOURCED=1

# Truecolor for Claude Code inside tmux. TWO env vars are required — one alone
# does nothing:
#   1. COLORTERM=truecolor — chalk/supports-color (which Claude's diff renderer
#      uses) reads COLORTERM, not terminfo; with TERM=tmux-256color and no
#      COLORTERM it caps at 256-color. This raises chalk's level to 24-bit.
#   2. CLAUDE_CODE_TMUX_TRUECOLOR=1 — Claude Code has a DELIBERATE clamp (added
#      v2.1.77, upstream issue #35148, verified in 2.1.210's binary):
#        if(env.CLAUDE_CODE_TMUX_TRUECOLOR) return;         // escape hatch
#        if(env.TMUX && chalk.level>2) chalk.level=2;       // force 256
#      It runs AFTER COLORTERM detection and knocks the level back to 256 unless
#      this var is set. So COLORTERM alone is silently undone; the escape hatch
#      alone has nothing to protect (level is already 256). Both together give
#      exact Midori washes (verified: bands emit 48;2;221;199;183 not 48;5;180).
# Undocumented var; must be exported from the shell (the clamp reads it at
# module load, before settings.json env injection).
if [ -n "$TMUX" ]; then
  export COLORTERM=truecolor
  export CLAUDE_CODE_TMUX_TRUECOLOR=1
fi

# Manuscript-style prompt: underlined sage path, middle-dot separators,
# plain foreground colors only (no filled powerline blocks).
if command -v oh-my-posh >/dev/null 2>&1; then
  eval "$(oh-my-posh init zsh --config ~/.config/midori.omp.json)"
fi

# fzf on the terminal's own 16-color palette (correct in both modes).
export FZF_DEFAULT_OPTS="--color=16,fg:-1,bg:-1,gutter:-1,hl:4,fg+:-1,bg+:-1,hl+:12,prompt:2,pointer:1,marker:3,spinner:6,info:8,header:8,border:8"

# Reset the cursor color to the theme's (OSC 112) before every prompt —
# full-screen apps (Claude Code among them) set their own cursor color via
# OSC 12 and can leave it behind on exit, turning the indigo cursor dark.
_midori_cursor_reset() { printf '\e]112\a'; }
precmd_functions+=(_midori_cursor_reset)

# eza: iconed, dir-first listings. Colors ride the terminal's ANSI-16
# palette, so they retint with the light/dark flip like everything else.
if command -v eza >/dev/null 2>&1; then
  alias ls='eza --icons=auto --group-directories-first'
  alias ll='eza -lh --icons=auto --group-directories-first --git'
  alias la='eza -lah --icons=auto --group-directories-first --git'
  alias tree='eza --tree --icons=auto --git-ignore'
fi

# zsh niceties without an oh-my-zsh dependency: autosuggestions + syntax
# highlighting from brew, skipped when a plugin manager already loaded them.
# (syntax-highlighting must be sourced last — this fragment is appended to
# the end of .zshrc, which satisfies that.)
_midori_bp="${HOMEBREW_PREFIX:-/opt/homebrew}"
[ -d "$_midori_bp" ] || _midori_bp=/usr/local
if ! typeset -f _zsh_autosuggest_start >/dev/null; then
  [ -f "$_midori_bp/share/zsh-autosuggestions/zsh-autosuggestions.zsh" ] && \
    source "$_midori_bp/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
fi
if ! typeset -f _zsh_highlight >/dev/null; then
  [ -f "$_midori_bp/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ] && \
    source "$_midori_bp/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
fi
unset _midori_bp

# zoxide: `z foo` jumps to the most-used directory matching "foo".
command -v zoxide >/dev/null 2>&1 && eval "$(zoxide init zsh)"

# Midori Claude Code diff patch — self-heal after any Claude Code update.
# The binary hardcodes diff colours; we patch it (see midori tools/). Updates
# (the native installer's updater, or a brew upgrade) restore the stock binary
# AND retarget the versioned path, so when the resolved path differs from the
# last-patched one, re-apply — here in an interactive shell (node/npx on PATH),
# only at launch, only after an update.
if [ -f "$HOME/.config/midori/apply-claude-midori-patch.sh" ]; then
  claude() {
    local real; real="$(readlink -f "$(command -v claude 2>/dev/null)" 2>/dev/null)"
    if [ -n "$real" ] && [ "$real" != "$(cat "$HOME/.config/midori/claude-patched-path" 2>/dev/null)" ]; then
      sh "$HOME/.config/midori/apply-claude-midori-patch.sh" || true
    fi
    command claude "$@"
  }
fi
