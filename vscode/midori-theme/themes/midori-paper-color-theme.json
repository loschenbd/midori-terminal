  "tokenColors": [
    {
      "name": "Comment — derived quiet warm gray (ink washed into paper)",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#8c8578", "fontStyle": "italic" }
    },
    {
      "name": "String — midori-olive",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#6c7d52" }
    },
    {
      "name": "Escapes & regex — dot-grid mint (deepened)",
      "scope": [
        "constant.character.escape",
        "string.regexp",
        "constant.other.character-class",
        "punctuation.definition.template-expression"
      ],
      "settings": { "foreground": "#548373" }
    },
    {
      "name": "Numbers & constants — terracotta (accent-warm-strong)",
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant",
        "constant.other",
        "keyword.other.unit"
      ],
      "settings": { "foreground": "#b06d4a" }
    },
    {
      "name": "Keywords & storage — midori-indigo (fountain-pen ink)",
      "scope": ["keyword", "keyword.control", "storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#3a5572" }
    },
    {
      "name": "Operators & punctuation — muted ink",
      "scope": ["keyword.operator", "punctuation", "meta.brace"],
      "settings": { "foreground": "#524d46" }
    },
    {
      "name": "Functions — midori-ochre",
      "scope": ["entity.name.function", "support.function", "meta.function-call.generic"],
      "settings": { "foreground": "#b88a3a" }
    },
    {
      "name": "Types & classes — midori-wine",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "support.type",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": { "foreground": "#7a4a4a" }
    },
    {
      "name": "Variables — ink",
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#2a2825" }
    },
    {
      "name": "Parameters — eyebrow ink (accent-mythic), italic",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#6b5f52", "fontStyle": "italic" }
    },
    {
      "name": "Properties — derived plum (wine × indigo)",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": { "foreground": "#664f63" }
    },
    {
      "name": "this / self — plum italic",
      "scope": ["variable.language"],
      "settings": { "foreground": "#664f63", "fontStyle": "italic" }
    },
    {
      "name": "Decorators & annotations — plum",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "punctuation.decorator",
        "storage.type.annotation"
      ],
      "settings": { "foreground": "#664f63" }
    },
    {
      "name": "Tags — indigo",
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": { "foreground": "#3a5572" }
    },
    {
      "name": "Attributes — ochre italic",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#b88a3a", "fontStyle": "italic" }
    },
    {
      "name": "CSS property names — muted ink",
      "scope": ["support.type.property-name.css", "support.type.vendored.property-name.css"],
      "settings": { "foreground": "#524d46" }
    },
    {
      "name": "JSON keys — indigo",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#3a5572" }
    },
    {
      "name": "Markdown heading — ink, bold",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": { "foreground": "#2a2825", "fontStyle": "bold" }
    },
    {
      "name": "Markdown heading / list punctuation — sage as punctuation",
      "scope": ["punctuation.definition.heading", "punctuation.definition.list"],
      "settings": { "foreground": "#5f6f5e" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic" }
    },
    {
      "name": "Markdown quote — eyebrow ink italic",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#6b5f52", "fontStyle": "italic" }
    },
    {
      "name": "Markdown inline code — warm deep",
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": { "foreground": "#8f4f38" }
    },
    {
      "name": "Links — indigo",
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": { "foreground": "#3a5572" }
    },
    {
      "name": "Diff / markup inserted — olive",
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#6c7d52" }
    },
    {
      "name": "Diff / markup deleted — warm deep",
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#8f4f38" }
    },
    {
      "name": "Diff / markup changed — ochre",
      "scope": ["markup.changed"],
      "settings": { "foreground": "#b88a3a" }
    },
    {
      "name": "Diff headers — indigo",
      "scope": ["meta.diff.header", "meta.diff.range"],
      "settings": { "foreground": "#3a5572" }
    },
    {
      "name": "Invalid — warm deep (site alert color, not red)",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#8f4f38" }
    }
  ],
  "semanticTokenColors": {
    "parameter": { "foreground": "#6b5f52", "italic": true },
    "property": "#664f63",
    "type": "#7a4a4a",
    "class": "#7a4a4a",
    "interface": "#7a4a4a",
    "enum": "#7a4a4a",
    "namespace": "#7a4a4a",
    "function": "#b88a3a",
    "method": "#b88a3a",
    "decorator": "#664f63"
  }
}
